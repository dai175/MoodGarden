#!/bin/bash
# Pre-commit hook: format and lint staged Swift files
# Install: make setup

set -euo pipefail

# Get staged .swift files (excluding deleted files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d -- '*.swift')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# --- swift-format ---
if command -v swift-format >/dev/null 2>&1; then
    echo "$STAGED_FILES" | xargs swift-format format --in-place
    echo "$STAGED_FILES" | xargs git add
else
    echo "warning: swift-format is not installed. Run 'brew install swift-format'"
fi

# --- SwiftLint ---
if command -v swiftlint >/dev/null 2>&1; then
    LINT_RESULT=0
    echo "$STAGED_FILES" | xargs swiftlint lint --quiet --strict || LINT_RESULT=$?

    if [ $LINT_RESULT -ne 0 ]; then
        echo ""
        echo "error: SwiftLint found violations. Fix them before committing."
        exit 1
    fi
else
    echo "warning: SwiftLint is not installed. Run 'brew install swiftlint'"
fi
